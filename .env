# 🎵 AI 智能音乐电台 - 配置文件

# ==============================================
# 必须配置项（朋友只需要填写这一项）
# ==============================================

# 网易云音乐 Cookie（必须）
# 获取方法：登录网易云网页版 → F12 → Application → Cookies → 复制所有Cookie
NETEASE_COOKIE=

# ==============================================
# 可选配置项（不填则使用默认配置）
# ==============================================

# 大模型配置（可选，不填则使用共享的API）
# LLM_API_KEY=你的API密钥
# LLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# LLM_MODEL=qwen-plus

# 天气配置（可选，不填则使用共享的天气API）
# WEATHER_API_KEY=
# CITY=Beijing

# ==============================================
# 高级配置（一般不需要修改）
# ==============================================

# 网易云开放平台（官方API，目前接口有问题）
# NETEASE_APP_ID=
# NETEASE_APP_SECRET=
# NETEASE_PRIVATE_KEY=
# NETEASE_PUBLIC_KEY=

# 网易云歌单ID（可选，默认同步"我喜欢的音乐"）
# NETEASE_PLAYLIST_ID=

# ==============================================
# 配置说明：
# 1. 只需要填写 NETEASE_COOKIE 即可使用
# 2. 其他配置项不填则使用默认值
# 3. 如果想使用自己的大模型API，取消注释并填写
# ==============================================